# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# Firebase Studio / nested Next app build artifacts
.firebase/**/node_modules/
.firebase/**/.next/
.firebase/**/hosting/

# env files (secrets — use .env.local for local dev, Firebase Secret Manager for prod)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.firebase/**/.env

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Firebase Studio IDE files
.idx/
.modified

# Firebase deployment cache
.firebase/*.cache
*.log
firebase-debug.log
